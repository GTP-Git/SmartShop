@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun PriceChartScreen(navController: NavHostController, vm: PriceViewModel, productName: String) {
    val history by vm.getHistoryForProduct(productName).collectAsState(initial = emptyList())

    Scaffold(topBar = { TopAppBar(title = { Text("Price Trend: $productName") }, navigationIcon = {
        IconButton(onClick = { navController.popBackStack() }) {
            Icon(imageVector = Icons.Default.ArrowBack, contentDescription = "Back")
        }
    }) }) { p ->
        Column(Modifier.fillMaxSize().padding(p).padding(16.dp)) {
            if (history.size < 2) {
                Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) { Text("Need at least 2 entries to show a trend.") }
            } else {
                // Chart uses normalized Ounce prices for accuracy
                val unitPrices = history.map { getPricePerOz(it.totalPrice, it.quantity, it.unit).toFloat() }
                val maxPrice = unitPrices.maxOrNull() ?: 1f
                val minPrice = unitPrices.minOrNull() ?: 0f
                val range = if (maxPrice - minPrice == 0f) 1f else maxPrice - minPrice

                Text("Price per Ounce over Time", fontWeight = FontWeight.Bold)
                Spacer(Modifier.height(24.dp))

                Canvas(modifier = Modifier.fillMaxWidth().height(300.dp).background(Color.White)) {
                    val width = size.width
                    val height = size.height
                    val spacing = width / (unitPrices.size - 1)

                    val points = unitPrices.mapIndexed { index, price ->
                        val x = index * spacing
                        val y = height - ((price - minPrice) / range * height * 0.8f + (height * 0.1f))
                        Offset(x, y)
                    }

                    val path = ComposePath().apply {
                        moveTo(points.first().x, points.first().y)
                        points.forEach { lineTo(it.x, it.y) }
                    }
                    drawPath(path, color = Color(0xFF2196F3), style = Stroke(width = 4.dp.toPx()))
                    points.forEach { drawCircle(color = Color(0xFF1976D2), radius = 6.dp.toPx(), center = it) }
                }

                Spacer(Modifier.height(16.dp))
                Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
                    Text("Oldest", fontSize = 12.sp)
                    Text("Newest", fontSize = 12.sp)
                }
            }
        }
    }
}
