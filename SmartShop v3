                                }
                                IconButton(onClick = { entryToDelete = entry }) {
                                    Icon(imageVector = Icons.Default.Delete, contentDescription = "Delete", tint = Color.Red)
                                }
                            }
                        }
                    )
                    HorizontalDivider()
                }
            }
        }
    }
}

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun PriceChartScreen(navController: NavHostController, vm: PriceViewModel, productName: String) {
    val history by vm.getHistoryForProduct(productName).collectAsState(initial = emptyList())

    Scaffold(topBar = { TopAppBar(title = { Text("Price Trend: $productName") }, navigationIcon = {
        IconButton(onClick = { navController.popBackStack() }) {
            Icon(imageVector = Icons.Default.ArrowBack, contentDescription = "Back")
        }
    }) }) { p ->
        Column(Modifier.fillMaxSize().padding(p).padding(16.dp)) {
            if (history.size < 2) {
                Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) { Text("Need at least 2 entries to show a trend.") }
            } else {
                val unitPrices = history.map { getPricePerOz(it.totalPrice, it.quantity, it.unit).toFloat() }
                val dates = history.map { it.date }

                val maxPrice = unitPrices.maxOrNull() ?: 1f
                val minPrice = unitPrices.minOrNull() ?: 0f
                val priceRange = if (maxPrice - minPrice == 0f) 1f else maxPrice - minPrice

                Text("Price per Ounce ($/oz)", fontWeight = FontWeight.Bold, style = MaterialTheme.typography.titleSmall)
                Spacer(Modifier.height(16.dp))

                Canvas(modifier = Modifier.fillMaxWidth().height(300.dp).background(Color.White)) {
                    val leftPadding = 100f
                    val bottomPadding = 80f
                    val topPadding = 40f
                    val rightPadding = 40f

                    val chartWidth = size.width - leftPadding - rightPadding
                    val chartHeight = size.height - topPadding - bottomPadding

                    drawLine(Color.Black, Offset(leftPadding, topPadding), Offset(leftPadding, size.height - bottomPadding), strokeWidth = 2f)
                    drawLine(Color.Black, Offset(leftPadding, size.height - bottomPadding), Offset(size.width - rightPadding, size.height - bottomPadding), strokeWidth = 2f)

                    val paint = Paint().apply {
                        color = android.graphics.Color.BLACK
                        textSize = 30f
                        typeface = Typeface.DEFAULT
                    }

                    val priceSteps = 4
                    for (i in 0..priceSteps) {
                        val priceLabel = minPrice + (priceRange / priceSteps * i)
                        val y = (size.height - bottomPadding) - (i.toFloat() / priceSteps * chartHeight)
                        drawContext.canvas.nativeCanvas.drawText(
                            "$${String.format(Locale.getDefault(), "%.2f", priceLabel)}",
                            10f, y + 10f, paint
                        )
                    }

                    val sdf = SimpleDateFormat("MM/dd", Locale.getDefault())
                    drawContext.canvas.nativeCanvas.drawText(sdf.format(Date(dates.first())), leftPadding, size.height - 20f, paint)
                    drawContext.canvas.nativeCanvas.drawText(sdf.format(Date(dates.last())), size.width - rightPadding - 80f, size.height - 20f, paint)

                    val spacing = chartWidth / (unitPrices.size - 1)
                    val points = unitPrices.mapIndexed { index, price ->
                        val x = leftPadding + (index * spacing)
                        val y = (size.height - bottomPadding) - ((price - minPrice) / priceRange * chartHeight)
                        Offset(x, y)
                    }

                    val path = ComposePath().apply {
                        moveTo(points.first().x, points.first().y)
                        points.forEach { lineTo(it.x, it.y) }
                    }

                    drawPath(path, color = Color(0xFF2196F3), style = Stroke(width = 4.dp.toPx()))
                    points.forEach { drawCircle(color = Color(0xFF1976D2), radius = 5.dp.toPx(), center = it) }
                }

                Spacer(Modifier.height(24.dp))
                Text("Timeline (Oldest to Newest)", modifier = Modifier.align(Alignment.CenterHorizontally), fontSize = 12.sp, color = Color.Gray)
            }
        }
    }
}
