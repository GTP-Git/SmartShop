// --- HELPER FUNCTIONS ---

fun getPricePerOz(totalPrice: Double, qty: Double, unit: String): Double {
    if (qty <= 0) return 0.0
    val factor = when (unit.lowercase()) {
        "oz" -> 1.0
        "lb" -> 16.0
        "g" -> 0.035274
        "kg" -> 35.274
        "ml" -> 0.033814
        "l" -> 33.814
        "gal" -> 128.0
        else -> 1.0
    }
    return totalPrice / (qty * factor)
}

fun calculateMedian(list: List<Double>): Double {
    if (list.isEmpty()) return 0.0
    val sorted = list.sorted()
    return if (sorted.size % 2 == 0) {
        (sorted[sorted.size / 2 - 1] + sorted[sorted.size / 2]) / 2.0
    } else {
        sorted[sorted.size / 2]
    }
}

// --- 1. API ---
data class OFFProductResponse(val product: OFFProduct?)
data class OFFProduct(val product_name: String?, val quantity: String?)
interface OpenFoodFactsApi {
    @GET("api/v0/product/{barcode}.json")
    suspend fun getProduct(@Path("barcode") barcode: String): OFFProductResponse
}
object RetrofitClient {
    val api: OpenFoodFactsApi by lazy {
        Retrofit.Builder().baseUrl("https://world.openfoodfacts.org/").addConverterFactory(GsonConverterFactory.create()).build().create(OpenFoodFactsApi::class.java)
    }
}

// --- 2. DATABASE ---
@Entity(tableName = "prices")
data class PriceEntry(
    @PrimaryKey(autoGenerate = true) val id: Int = 0,
    val name: String,
    val totalPrice: Double,
    val quantity: Double,
    val unit: String,
    val date: Long,
    val barcode: String? = null
)

@Dao
interface PriceDao {
    @Insert suspend fun insert(entry: PriceEntry)
    @Update suspend fun update(entry: PriceEntry)
    @Delete suspend fun delete(entry: PriceEntry)
    @Query("SELECT * FROM prices ORDER BY date DESC") fun getAllPrices(): Flow<List<PriceEntry>>
    @Query("SELECT * FROM prices WHERE id = :id LIMIT 1") suspend fun getEntryById(id: Int): PriceEntry?
    @Query("SELECT * FROM prices WHERE name LIKE '%' || :query || '%' ORDER BY date DESC") fun searchPrices(query: String): Flow<List<PriceEntry>>
    @Query("SELECT * FROM prices WHERE LOWER(name) = LOWER(:productName) OR barcode = :productName ORDER BY date ASC")
    fun getHistoryForProduct(productName: String): Flow<List<PriceEntry>>
    @Query("SELECT DISTINCT name FROM prices WHERE name LIKE '%' || :query || '%' LIMIT 5")
    fun getSuggestedNames(query: String): Flow<List<String>>
    @Query("SELECT * FROM prices WHERE name = :name ORDER BY date DESC LIMIT 1")
    suspend fun getLastEntryForName(name: String): PriceEntry?
}

@Database(entities = [PriceEntry::class], version = 3)
abstract class AppDatabase : RoomDatabase() {
    abstract fun priceDao(): PriceDao
    companion object {
        @Volatile var INSTANCE: AppDatabase? = null
        fun getDatabase(context: android.content.Context): AppDatabase {
            return INSTANCE ?: synchronized(this) {
                val instance = Room.databaseBuilder(context.applicationContext, AppDatabase::class.java, "shop_db").fallbackToDestructiveMigration().build()
                INSTANCE = instance
                instance
            }
        }
    }
}

// --- 3. VIEWMODEL ---
class PriceViewModel(application: Application) : AndroidViewModel(application) {
    private val db = AppDatabase.getDatabase(application)
    private val searchQuery = MutableStateFlow("")

    // --- GEMINI SETUP ---
    private var generativeModel = GenerativeModel(
        modelName = "gemini-2.5-flash",
        apiKey = Secrets.GEMINI_API_KEY.trim()
    )

    var aiResponse by mutableStateOf<String?>(null)
    var isAiLoading by mutableStateOf(false)

    @OptIn(kotlinx.coroutines.ExperimentalCoroutinesApi::class)
    val filteredPrices = searchQuery.flatMapLatest { query ->
        if (query.isEmpty()) db.priceDao().getAllPrices() else db.priceDao().searchPrices(query)
    }

    fun setSearchQuery(query: String) { searchQuery.value = query }
    fun getHistoryForProduct(name: String) = db.priceDao().getHistoryForProduct(name)
    fun getSuggestedNames(query: String) = db.priceDao().getSuggestedNames(query)
    suspend fun getEntryById(id: Int) = db.priceDao().getEntryById(id)
    suspend fun getLastEntryForName(name: String) = db.priceDao().getLastEntryForName(name)

    fun saveOrUpdatePrice(id: Int, name: String, p: String, q: String, u: String, d: Long, b: String?) {
        val entry = PriceEntry(id, name, p.toDoubleOrNull() ?: 0.0, q.toDoubleOrNull() ?: 1.0, u, d, b)
        viewModelScope.launch { if (id == 0) db.priceDao().insert(entry) else db.priceDao().update(entry) }
    }
    fun deletePrice(entry: PriceEntry) { viewModelScope.launch { db.priceDao().delete(entry) } }

    suspend fun fetchProduct(barcode: String) = try {
        val res = RetrofitClient.api.getProduct(barcode)
        Pair(res.product?.product_name, res.product?.quantity)
    } catch (e: Exception) { Pair(null, null) }

    fun getAiShoppingTip() {
        viewModelScope.launch {
            isAiLoading = true
            aiResponse = "Analyzing unit prices..."
            try {
                val history = db.priceDao().getAllPrices().first()

                if (history.isEmpty()) {
                    aiResponse = "Add some items first so I can analyze your shopping habits!"
                } else {
                    val historyText = history.take(15).joinToString(" | ") {
                        val unitPrice = getPricePerOz(it.totalPrice, it.quantity, it.unit)
                        "${it.name}: $${it.totalPrice} for ${it.quantity}${it.unit} ($${String.format(Locale.getDefault(), "%.2f", unitPrice)}/oz)"
                    }

                    val prompt = """
                        You are a blunt, highly analytical grocery budget advisor. 
                        Here is the user's recent purchase history with unit prices:
                        $historyText
                        
                        CRITICAL RULES:
                        1. DO NOT give generic advice (e.g., "compare prices", "buy in bulk", "look for sales").
                        2. Make ONE specific, actionable observation based ONLY on the data provided. 
                        3. Point out the most expensive item by unit weight, or note a specific price trend.
                        4. Keep it to a single, concise sentence.
                    """.trimIndent()

                    val response = generativeModel.generateContent(prompt)
                    aiResponse = response.text?.replace("\n", "") ?: "AI returned empty response."
                }

            } catch (e: Exception) {
                val errorMsg = e.localizedMessage ?: "Unknown Error"
                Log.e("SmartShop", "AI Error: $errorMsg", e)

                if (errorMsg.contains("404")) {
                    aiResponse = "Trying fallback model..."
                    try {
                        generativeModel = GenerativeModel("gemini-2.0-flash", Secrets.GEMINI_API_KEY.trim())
                        // Use a slightly simpler prompt for the fallback just in case
                        val fallbackPrompt = "You are a grocery analyst. Look at this data: ${db.priceDao().getAllPrices().first().take(5).joinToString { it.name }}. Give one highly specific pricing insight."
                        val fallbackResponse = generativeModel.generateContent(fallbackPrompt)
                        aiResponse = fallbackResponse.text
                    } catch (e2: Exception) {
                        aiResponse = "Error 404: The requested AI model is retired or not found. Check Google AI Studio for active model names."
                    }
                } else {
                    aiResponse = "AI Error: ${e.javaClass.simpleName} - $errorMsg"
                }
            } finally {
                isAiLoading = false
            }
        }
    }
}

