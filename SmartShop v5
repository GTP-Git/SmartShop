@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun PriceChartScreen(navController: NavHostController, vm: PriceViewModel, productName: String) {
    val history by vm.getHistoryForProduct(productName).collectAsState(initial = emptyList())
    Scaffold(topBar = { TopAppBar(title = { Text("Price Trend: $productName") }, navigationIcon = { IconButton(onClick = { navController.popBackStack() }) { Icon(Icons.Default.ArrowBack, null) } }) }) { p ->
        Column(Modifier.fillMaxSize().padding(p).padding(16.dp)) {
            if (history.size < 2) { Box(Modifier.fillMaxSize(), Alignment.Center) { Text("Need at least 2 entries for a trend.") } }
            else {
                val unitPrices = history.map { getPricePerOz(it.totalPrice, it.quantity, it.unit).toFloat() }
                val maxPrice = unitPrices.maxOrNull() ?: 1f
                val minPrice = unitPrices.minOrNull() ?: 0f
                val range = if (maxPrice - minPrice == 0f) 1f else maxPrice - minPrice

                Canvas(Modifier.fillMaxWidth().height(300.dp).background(Color.White)) {
                    val lp = 100f; val bp = 80f; val tp = 40f; val rp = 40f
                    val cw = size.width - lp - rp; val ch = size.height - tp - bp
                    drawLine(Color.Black, Offset(lp, tp), Offset(lp, size.height - bp), 2f)
                    drawLine(Color.Black, Offset(lp, size.height - bp), Offset(size.width - rp, size.height - bp), 2f)
                    val paint = Paint().apply { color = android.graphics.Color.BLACK; textSize = 30f }
                    for (i in 0..4) {
                        val price = minPrice + (range / 4 * i)
                        val y = (size.height - bp) - (i.toFloat() / 4 * ch)
                        drawContext.canvas.nativeCanvas.drawText("$${String.format("%.2f", price)}", 10f, y + 10f, paint)
                    }
                    val spacing = cw / (unitPrices.size - 1)
                    val points = unitPrices.mapIndexed { i, price -> Offset(lp + (i * spacing), (size.height - bp) - ((price - minPrice) / range * ch)) }
                    val path = ComposePath().apply { moveTo(points[0].x, points[0].y); points.forEach { lineTo(it.x, it.y) } }
                    drawPath(path, Color(0xFF2196F3), style = Stroke(4.dp.toPx()))
                    points.forEach { drawCircle(Color(0xFF1976D2), 5.dp.toPx(), it) }
                }
            }
        }
    }
}
