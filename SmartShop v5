@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun CompareScreen(
    navController: NavHostController,
    vm: PriceViewModel,
    scannedCodeA: String?,
    scannedCodeB: String?,
    onClearA: () -> Unit,
    onClearB: () -> Unit,
    onLaunchScanner: (String) -> Unit
) {
    val units = listOf("oz", "lb", "g", "kg", "ml", "l", "count", "pack", "gal")

    var nameA by remember { mutableStateOf("") }
    var priceA by remember { mutableStateOf("") }
    var qtyA by remember { mutableStateOf("") }
    var unitA by remember { mutableStateOf("oz") }
    var unitMenuExpandedA by remember { mutableStateOf(false) }
    var isSearchingA by remember { mutableStateOf(false) }

    var nameB by remember { mutableStateOf("") }
    var priceB by remember { mutableStateOf("") }
    var qtyB by remember { mutableStateOf("") }
    var unitB by remember { mutableStateOf("oz") }
    var unitMenuExpandedB by remember { mutableStateOf(false) }
    var isSearchingB by remember { mutableStateOf(false) }

    LaunchedEffect(scannedCodeA) {
        if (scannedCodeA != null) {
            isSearchingA = true
            val (n, q) = vm.fetchProduct(scannedCodeA)
            if (!n.isNullOrBlank()) nameA = n
            if (!q.isNullOrBlank()) {
                val parsed = parseQuantityAndUnit(q, units)
                if (parsed != null) { qtyA = parsed.first; unitA = parsed.second }
            }
            isSearchingA = false
            onClearA()
        }
    }

    LaunchedEffect(scannedCodeB) {
        if (scannedCodeB != null) {
            isSearchingB = true
            val (n, q) = vm.fetchProduct(scannedCodeB)
            if (!n.isNullOrBlank()) nameB = n
            if (!q.isNullOrBlank()) {
                val parsed = parseQuantityAndUnit(q, units)
                if (parsed != null) { qtyB = parsed.first; unitB = parsed.second }
            }
            isSearchingB = false
            onClearB()
        }
    }

    val unitPriceA = getPricePerOz(priceA.toDoubleOrNull() ?: 0.0, qtyA.toDoubleOrNull() ?: 0.0, unitA)
    val unitPriceB = getPricePerOz(priceB.toDoubleOrNull() ?: 0.0, qtyB.toDoubleOrNull() ?: 0.0, unitB)

    Scaffold(topBar = {
        TopAppBar(title = { Text("Quick Compare") }, navigationIcon = {
            IconButton(onClick = { navController.popBackStack() }) {
                Icon(imageVector = Icons.Default.ArrowBack, contentDescription = "Back")
            }
        })
    }) { p ->
        LazyColumn(Modifier.fillMaxSize().padding(p).padding(16.dp), verticalArrangement = Arrangement.spacedBy(16.dp)) {
            item {
                Card(Modifier.fillMaxWidth(), colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surfaceVariant)) {
                    Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(8.dp)) {
                        Row(Modifier.fillMaxWidth(), Arrangement.SpaceBetween, Alignment.CenterVertically) {
                            Text("Item A", fontWeight = FontWeight.Bold, color = MaterialTheme.colorScheme.primary)
                            IconButton(onClick = { onLaunchScanner("compareA") }) { Icon(Icons.Default.Search, null) }
                        }
                        OutlinedTextField(nameA, { nameA = it }, label = { Text("Name") }, modifier = Modifier.fillMaxWidth())
                        Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                            OutlinedTextField(priceA, { priceA = it }, label = { Text("Price $") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                            OutlinedTextField(qtyA, { qtyA = it }, label = { Text("Size") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                        }
                        Box(Modifier.fillMaxWidth()) {
                            OutlinedTextField(unitA, {}, readOnly = true, label = { Text("Unit") }, modifier = Modifier.fillMaxWidth(), trailingIcon = { Icon(Icons.Default.ArrowDropDown, null, Modifier.clickable { unitMenuExpandedA = true }) })
                            Box(Modifier.matchParentSize().clickable { unitMenuExpandedA = true })
                            DropdownMenu(expanded = unitMenuExpandedA, onDismissRequest = { unitMenuExpandedA = false }) {
                                units.forEach { u -> DropdownMenuItem(text = { Text(u) }, onClick = { unitA = u; unitMenuExpandedA = false }) }
                            }
                        }
                    }
                }
            }

            item {
                Card(Modifier.fillMaxWidth(), colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surfaceVariant)) {
                    Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(8.dp)) {
                        Row(Modifier.fillMaxWidth(), Arrangement.SpaceBetween, Alignment.CenterVertically) {
                            Text("Item B", fontWeight = FontWeight.Bold, color = MaterialTheme.colorScheme.primary)
                            IconButton(onClick = { onLaunchScanner("compareB") }) { Icon(Icons.Default.Search, null) }
                        }
                        OutlinedTextField(nameB, { nameB = it }, label = { Text("Name") }, modifier = Modifier.fillMaxWidth())
                        Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                            OutlinedTextField(priceB, { priceB = it }, label = { Text("Price $") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                            OutlinedTextField(qtyB, { qtyB = it }, label = { Text("Size") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                        }
                        Box(Modifier.fillMaxWidth()) {
                            OutlinedTextField(unitB, {}, readOnly = true, label = { Text("Unit") }, modifier = Modifier.fillMaxWidth(), trailingIcon = { Icon(Icons.Default.ArrowDropDown, null, Modifier.clickable { unitMenuExpandedB = true }) })
                            Box(Modifier.matchParentSize().clickable { unitMenuExpandedB = true })
                            DropdownMenu(expanded = unitMenuExpandedB, onDismissRequest = { unitMenuExpandedB = false }) {
                                units.forEach { u -> DropdownMenuItem(text = { Text(u) }, onClick = { unitB = u; unitMenuExpandedB = false }) }
                            }
                        }
                    }
                }
            }

            if (unitPriceA > 0 && unitPriceB > 0) {
                item {
                    val isATie = Math.abs(unitPriceA - unitPriceB) < 0.0001
                    val winner = if (unitPriceA < unitPriceB) "A" else "B"
                    val diff = Math.abs(unitPriceA - unitPriceB)
                    Card(Modifier.fillMaxWidth(), colors = CardDefaults.cardColors(containerColor = if (isATie) Color.LightGray else Color(0xFFE8F5E9))) {
                        Column(Modifier.padding(16.dp).fillMaxWidth(), horizontalAlignment = Alignment.CenterHorizontally) {
                            if (isATie) {
                                Text("It's a Tie!", fontWeight = FontWeight.Bold)
                            } else {
                                val winnerName = if (winner == "A") (nameA.ifBlank { "Item A" }) else (nameB.ifBlank { "Item B" })
                                Text("🏆 $winnerName Wins!", fontWeight = FontWeight.Bold, fontSize = 20.sp, color = Color(0xFF2E7D32))
                                Text("${String.format(Locale.getDefault(), "%.1f", (diff / Math.max(unitPriceA, unitPriceB)) * 100)}% Cheaper", color = Color(0xFF2E7D32))
                            }
                        }
                    }
                }
            }
        }
    }
}

