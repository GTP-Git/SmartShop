    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent {
            MaterialTheme {
                val navController = rememberNavController()
                val vm: PriceViewModel = viewModel()

                var activeScanner by remember { mutableStateOf("") }
                var scannedCodeEntry by remember { mutableStateOf<String?>(null) }
                var scannedCodeCompareA by remember { mutableStateOf<String?>(null) }
                var scannedCodeCompareB by remember { mutableStateOf<String?>(null) }

                NavHost(navController, startDestination = "main") {
                    composable("main") { MainScreen(navController, vm) }
                    composable("entry?entryId={entryId}", arguments = listOf(navArgument("entryId") { type = NavType.IntType; defaultValue = 0 })) { backStackEntry ->
                        EntryScreen(
                            navController,
                            vm,
                            scannedCodeEntry,
                            backStackEntry.arguments?.getInt("entryId") ?: 0,
                            onClear = { scannedCodeEntry = null },
                            onLaunchScanner = {
                                activeScanner = "entry"
                                navController.navigate("scanner")
                            }
                        )
                    }
                    composable("compare") {
                        CompareScreen(
                            navController,
                            vm,
                            scannedCodeCompareA,
                            scannedCodeCompareB,
                            onClearA = { scannedCodeCompareA = null },
                            onClearB = { scannedCodeCompareB = null },
                            onLaunchScanner = { target ->
                                activeScanner = target
                                navController.navigate("scanner")
                            }
                        )
                    }
                    composable("options") { OptionsScreen(navController, vm) }
                    composable("scanner") {
                        ScannerScreen { code ->
                            when (activeScanner) {
                                "entry" -> scannedCodeEntry = code
                                "compareA" -> scannedCodeCompareA = code
                                "compareB" -> scannedCodeCompareB = code
                            }
                            navController.popBackStack()
                        }
                    }
                    composable("chart/{productName}") { backStackEntry ->
                        PriceChartScreen(navController, vm, backStackEntry.arguments?.getString("productName") ?: "")
                    }
                }
            }
        }
    }
}

