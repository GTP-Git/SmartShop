    var name by remember { mutableStateOf("") }
    var priceInput by remember { mutableStateOf("") }
    var qtyInput by remember { mutableStateOf("") }
    var unit by remember { mutableStateOf("oz") }
    var store by remember { mutableStateOf(vm.lastUsedStore) }
    var barcode by remember { mutableStateOf<String?>(null) }
    var isSearching by remember { mutableStateOf(false) }
    var unitMenuExpanded by remember { mutableStateOf(false) }
    var showSuggestions by remember { mutableStateOf(false) }

    val history by vm.getHistoryForProduct(name).collectAsState(initial = emptyList())
    val suggestions by vm.getSuggestedNames(name).collectAsState(initial = emptyList())
    val dateState = rememberDatePickerState(initialSelectedDateMillis = System.currentTimeMillis())
    var showDate by remember { mutableStateOf(false) }
    val units = listOf("oz", "lb", "g", "kg", "ml", "l", "count", "pack", "gal")
    val scope = rememberCoroutineScope()

    LaunchedEffect(entryId) {
        if (entryId != 0) {
            vm.getEntryById(entryId)?.let {
                name = it.name; priceInput = it.totalPrice.toString(); qtyInput = it.quantity.toString(); unit = it.unit; barcode = it.barcode; store = it.store
            }
        }
    }

    LaunchedEffect(scannedCode) {
        if (scannedCode != null) {
            barcode = scannedCode; isSearching = true
            val (n, q) = vm.fetchProduct(scannedCode)
            if (!n.isNullOrBlank()) name = n
            if (!q.isNullOrBlank()) {
                val parsed = parseQuantityAndUnit(q, units)
                if (parsed != null) { qtyInput = parsed.first; unit = parsed.second }
            }
            isSearching = false; onClear()
        }
    }

    if (showDate) {
        DatePickerDialog(onDismissRequest = { showDate = false }, confirmButton = { TextButton(onClick = { showDate = false }) { Text("OK") } }) { DatePicker(dateState) }
    }

    Scaffold(topBar = { TopAppBar(title = { Text(if (entryId == 0) "New Entry" else "Edit Entry") }, navigationIcon = {
        IconButton(onClick = { navController.popBackStack() }) {
            Icon(imageVector = Icons.Default.ArrowBack, contentDescription = "Back")
        }
    }) }) { p ->
        LazyColumn(Modifier.fillMaxSize().padding(p).padding(16.dp), verticalArrangement = Arrangement.spacedBy(16.dp)) {
            item {
                Button(onClick = { onLaunchScanner() }, Modifier.fillMaxWidth(), colors = ButtonDefaults.buttonColors(containerColor = MaterialTheme.colorScheme.tertiary)) {
                    Icon(imageVector = Icons.Default.Search, contentDescription = null)
                    Spacer(Modifier.width(8.dp))
                    Text("Scan Barcode")
                }
            }

            if (isSearching) item { LinearProgressIndicator(Modifier.fillMaxWidth()) }

            item {
                OutlinedTextField(value = store, onValueChange = { store = it }, label = { Text("Store (e.g. H-E-B, Walmart)") }, modifier = Modifier.fillMaxWidth(), singleLine = true)
            }

            item {
                Box {
                    OutlinedTextField(value = name, onValueChange = { name = it; showSuggestions = it.isNotEmpty() }, label = { Text("Product Name") }, modifier = Modifier.fillMaxWidth())
                    if (showSuggestions && suggestions.isNotEmpty()) {
                        DropdownMenu(expanded = showSuggestions, onDismissRequest = { showSuggestions = false }, properties = PopupProperties(focusable = false), modifier = Modifier.fillMaxWidth(0.8f)) {
                            suggestions.forEach { suggestion ->
                                DropdownMenuItem(text = { Text(suggestion) }, onClick = {
                                    name = suggestion; showSuggestions = false
                                    scope.launch { vm.getLastEntryForName(suggestion)?.let { unit = it.unit; qtyInput = it.quantity.toString() } }
                                })
                            }
                        }
                    }
                }
            }

            if (history.isNotEmpty() && name.length > 2) {
                item {
                    val currentPriceOz = getPricePerOz(priceInput.toDoubleOrNull() ?: 0.0, qtyInput.toDoubleOrNull() ?: 0.0, unit)
                    val historyUnitPricesOz = history.map { getPricePerOz(it.totalPrice, it.quantity, it.unit) }
                    val bestPriceOz = historyUnitPricesOz.minOrNull() ?: 0.0
                    Card(Modifier.fillMaxWidth(), colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.secondaryContainer)) {
                        Column(Modifier.padding(12.dp)) {
                            Text("Product Insights", style = MaterialTheme.typography.labelLarge, color = MaterialTheme.colorScheme.primary)
                            if (currentPriceOz > 0) {
                                val isNewBest = currentPriceOz < (bestPriceOz - 0.001)
                                Text(if (isNewBest) "🌟 NEW BEST PRICE!" else if (currentPriceOz > bestPriceOz) "Higher than best" else "Matches best price", fontWeight = FontWeight.Bold)
                            }
                            Text("Best recorded: $${String.format(Locale.getDefault(), "%.2f", bestPriceOz)}/oz")
                        }
                    }
                }
            }

            item {
                Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                    OutlinedTextField(priceInput, { priceInput = it }, label = { Text("Price") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                    OutlinedTextField(qtyInput, { qtyInput = it }, label = { Text("Size") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                }
            }

            item {
                Box(modifier = Modifier.fillMaxWidth()) {
                    OutlinedTextField(value = unit, onValueChange = {}, readOnly = true, label = { Text("Unit") }, modifier = Modifier.fillMaxWidth(), trailingIcon = { Icon(Icons.Default.ArrowDropDown, null, Modifier.clickable { unitMenuExpanded = true }) })
                    Box(Modifier.matchParentSize().clickable { unitMenuExpanded = true })
                    DropdownMenu(expanded = unitMenuExpanded, onDismissRequest = { unitMenuExpanded = false }) {
                        units.forEach { u -> DropdownMenuItem(text = { Text(u) }, onClick = { unit = u; unitMenuExpanded = false }) }
                    }
                }
            }

            item {
                Row(Modifier.fillMaxWidth(), Arrangement.SpaceBetween, Alignment.CenterVertically) {
                    Text("Date: ${SimpleDateFormat("MMM dd", Locale.getDefault()).format(Date(dateState.selectedDateMillis ?: 0))}")
                    TextButton(onClick = { showDate = true }) { Text("Change Date") }
                }
            }

            item {
                Button(onClick = {
                    if (name.isNotBlank() && priceInput.isNotBlank()) {
                        vm.saveOrUpdatePrice(entryId, name, priceInput, qtyInput, unit, dateState.selectedDateMillis ?: 0, barcode, store)
                        navController.popBackStack()
                    }
                }, Modifier.fillMaxWidth().height(60.dp)) { Text(if (entryId == 0) "Save Price" else "Update Price") }
            }
        }
    }
}

@Composable
fun ScannerScreen(onScanned: (String) -> Unit) {
    val context = LocalContext.current
    val lifecycleOwner = LocalLifecycleOwner.current
    var hasPermission by remember { mutableStateOf(ContextCompat.checkSelfPermission(context, Manifest.permission.CAMERA) == PackageManager.PERMISSION_GRANTED) }
    val launcher = rememberLauncherForActivityResult(ActivityResultContracts.RequestPermission()) { hasPermission = it }
    var isDetected by remember { mutableStateOf(false) }
    LaunchedEffect(Unit) { if (!hasPermission) launcher.launch(Manifest.permission.CAMERA) }
    if (hasPermission) {
        AndroidView(factory = { ctx ->
            val previewView = PreviewView(ctx)
            val cameraProviderFuture = ProcessCameraProvider.getInstance(ctx)
            cameraProviderFuture.addListener({
                val cameraProvider = cameraProviderFuture.get()
                val preview = Preview.Builder().build().apply { setSurfaceProvider(previewView.surfaceProvider) }
                val scanner = BarcodeScanning.getClient()
                val analysis = ImageAnalysis.Builder().setBackpressureStrategy(ImageAnalysis.STRATEGY_KEEP_ONLY_LATEST).build()
                analysis.setAnalyzer(Executors.newSingleThreadExecutor()) { proxy ->
                    val mediaImage = proxy.image
                    if (mediaImage != null && !isDetected) {
                        val image = InputImage.fromMediaImage(mediaImage, proxy.imageInfo.rotationDegrees)
                        scanner.process(image).addOnSuccessListener { barcodes ->
                            if (barcodes.isNotEmpty() && !isDetected) { isDetected = true; barcodes[0].rawValue?.let { onScanned(it) } }
                        }.addOnCompleteListener { proxy.close() }
                    } else { proxy.close() }
                }
                cameraProvider.unbindAll()
                cameraProvider.bindToLifecycle(lifecycleOwner, CameraSelector.DEFAULT_BACK_CAMERA, preview, analysis)
            }, ContextCompat.getMainExecutor(ctx))
            previewView
        }, modifier = Modifier.fillMaxSize())
    }
}

