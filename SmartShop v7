// --- 2. DATABASE ---

@Entity(tableName = "prices")
data class PriceEntry(
    @PrimaryKey(autoGenerate = true) val id: Int = 0,
    val name: String,
    val totalPrice: Double,
    val quantity: Double,
    val unit: String,
    val date: Long,
    val barcode: String? = null,
    val store: String = ""
)

@Entity(tableName = "shopping_list")
data class ShoppingItem(
    @PrimaryKey(autoGenerate = true) val id: Int = 0,
    val name: String,
    val isChecked: Boolean = false
)

@Dao
interface PriceDao {
    @Insert suspend fun insert(entry: PriceEntry)
    @Update suspend fun update(entry: PriceEntry)
    @Delete suspend fun delete(entry: PriceEntry)
    @Query("SELECT * FROM prices ORDER BY date DESC") fun getAllPrices(): Flow<List<PriceEntry>>
    @Query("SELECT * FROM prices WHERE id = :id LIMIT 1") suspend fun getEntryById(id: Int): PriceEntry?
    @Query("SELECT * FROM prices WHERE name LIKE '%' || :query || '%' ORDER BY date DESC") fun searchPrices(query: String): Flow<List<PriceEntry>>
    @Query("SELECT * FROM prices WHERE LOWER(name) = LOWER(:productName) OR barcode = :productName ORDER BY date ASC")
    fun getHistoryForProduct(productName: String): Flow<List<PriceEntry>>
    @Query("SELECT DISTINCT name FROM prices WHERE name LIKE '%' || :query || '%' LIMIT 5")
    fun getSuggestedNames(query: String): Flow<List<String>>
    @Query("SELECT * FROM prices WHERE name = :name OR barcode = :name ORDER BY date DESC LIMIT 1")
    suspend fun getLastEntryForName(name: String): PriceEntry?
    @Query("DELETE FROM prices") suspend fun deleteAllPrices()
    @Query("SELECT store FROM prices WHERE store != '' ORDER BY date DESC LIMIT 1")
    suspend fun getLastUsedStore(): String?
    @Query("SELECT name, date FROM prices ORDER BY name ASC, date ASC")
    suspend fun getProductPurchaseHistory(): List<ProductDate>

    // Shopping List Queries
    @Insert suspend fun insertShoppingItem(item: ShoppingItem)
    @Update suspend fun updateShoppingItem(item: ShoppingItem)
    @Delete suspend fun deleteShoppingItem(item: ShoppingItem)
    @Query("SELECT * FROM shopping_list ORDER BY isChecked ASC, id DESC")
    fun getShoppingList(): Flow<List<ShoppingItem>>
    @Query("DELETE FROM shopping_list WHERE isChecked = 1")
    suspend fun clearCheckedShoppingItems()
}

data class ProductDate(val name: String, val date: Long)

@Database(entities = [PriceEntry::class, ShoppingItem::class], version = 5)
abstract class AppDatabase : RoomDatabase() {
    abstract fun priceDao(): PriceDao
    companion object {
        @Volatile var INSTANCE: AppDatabase? = null
        fun getDatabase(context: android.content.Context): AppDatabase {
            return INSTANCE ?: synchronized(this) {
                val instance = Room.databaseBuilder(context.applicationContext, AppDatabase::class.java, "shop_db")
                    .fallbackToDestructiveMigration()
                    .build()
                INSTANCE = instance
                instance
            }
        }
    }
}

// --- 3. VIEWMODEL ---
class PriceViewModel(application: Application) : AndroidViewModel(application) {
    private val db = AppDatabase.getDatabase(application)
    private val searchQuery = MutableStateFlow("")

    private var generativeModel = GenerativeModel(
        modelName = "gemini-2.5-flash", 
        apiKey = Secrets.GEMINI_API_KEY.trim()
    )

    var aiResponse by mutableStateOf<String?>(null)
    var isAiLoading by mutableStateOf(false)
    var lastUsedStore by mutableStateOf("")

    var suggestedRestocks by mutableStateOf<List<String>>(emptyList())
    val shoppingList = db.priceDao().getShoppingList()

    init {
        viewModelScope.launch {
            lastUsedStore = db.priceDao().getLastUsedStore() ?: ""
            calculateRestockSuggestions()
        }
    }

    @OptIn(kotlinx.coroutines.ExperimentalCoroutinesApi::class)
    val filteredPrices = searchQuery.flatMapLatest { query ->
        if (query.isEmpty()) db.priceDao().getAllPrices() else db.priceDao().searchPrices(query)
    }

    fun setSearchQuery(query: String) { searchQuery.value = query }
    fun getHistoryForProduct(name: String) = db.priceDao().getHistoryForProduct(name)
    fun getSuggestedNames(query: String) = db.priceDao().getSuggestedNames(query)
    suspend fun getEntryById(id: Int) = db.priceDao().getEntryById(id)
    suspend fun getLastEntryForName(name: String) = db.priceDao().getLastEntryForName(name)

    fun saveOrUpdatePrice(id: Int, name: String, p: String, q: String, u: String, d: Long, b: String?, store: String) {
        val entry = PriceEntry(id, name, p.toDoubleOrNull() ?: 0.0, q.toDoubleOrNull() ?: 1.0, u, d, b, store)
        lastUsedStore = store
        viewModelScope.launch { 
            if (id == 0) db.priceDao().insert(entry) else db.priceDao().update(entry)
            calculateRestockSuggestions() 
        }
    }

    fun deletePrice(entry: PriceEntry) { viewModelScope.launch { db.priceDao().delete(entry) } }
    fun deleteAllPrices() { viewModelScope.launch { db.priceDao().deleteAllPrices() } }

    fun addItemToList(name: String) {
        viewModelScope.launch { db.priceDao().insertShoppingItem(ShoppingItem(name = name)) }
    }
    fun toggleShoppingItem(item: ShoppingItem) {
        viewModelScope.launch { db.priceDao().updateShoppingItem(item.copy(isChecked = !item.isChecked)) }
    }
    fun deleteShoppingItem(item: ShoppingItem) {
        viewModelScope.launch { db.priceDao().deleteShoppingItem(item) }
    }
    fun clearCheckedItems() {
        viewModelScope.launch { db.priceDao().clearCheckedShoppingItems() }
    }

    suspend fun calculateRestockSuggestions() {
        val history = db.priceDao().getProductPurchaseHistory()
        if (history.isEmpty()) return
        
        val now = System.currentTimeMillis()
        val suggestions = mutableListOf<String>()
        val grouped = history.groupBy({ it.name }, { it.date })

        grouped.forEach { (name, dates) ->
            if (dates.size >= 2) {
                val sorted = dates.sorted()
                val totalDays = (sorted.last() - sorted.first()) / (1000 * 60 * 60 * 24)
                val avgInterval = totalDays.toDouble() / (dates.size - 1)
                val daysSinceLast = (now - sorted.last()) / (1000 * 60 * 60 * 24)
                
                if (daysSinceLast >= (avgInterval - 1)) {
                    suggestions.add(name)
                }
            }
        }
        suggestedRestocks = suggestions
    }

    suspend fun fetchProduct(barcode: String): Pair<String?, String?> {
        var name: String? = null
        var size: String? = null
        try {
            val upcRes = RetrofitClient.upcApi.getProduct(barcode)
            if (!upcRes.items.isNullOrEmpty()) {
                name = upcRes.items[0].title
                size = upcRes.items[0].size ?: upcRes.items[0].weight
            }
        } catch (e: Exception) { Log.e("SmartShop", "UPC API failed") }
        if (name.isNullOrBlank()) {
            try {
                val offRes = RetrofitClient.offApi.getProduct(barcode)
                name = offRes.product?.product_name
                size = offRes.product?.quantity
            } catch (e: Exception) { Log.e("SmartShop", "OFF API failed") }
        }
        return Pair(name, size)
    }

    fun getAiShoppingTip() {
        viewModelScope.launch {
            isAiLoading = true
            aiResponse = "Thinking..."
            try {
                val history = db.priceDao().getAllPrices().first()
                if (history.isEmpty()) {
                    aiResponse = "Add some price entries first!"
                } else {
                    val historyText = history.take(25).joinToString(" | ") {
                        val unitPrice = getPricePerOz(it.totalPrice, it.quantity, it.unit)
                        "${it.name} at ${it.store}: $${String.format("%.2f", unitPrice)}/oz"
                    }
                    val prompt = "User History: $historyText. Based ONLY on this, give a specific, blunt budget observation about where to buy a specific item or which item is costing too much. Quantify the price difference."
                    
                    val response = generativeModel.generateContent(prompt)
                    aiResponse = response.text?.replace("\n", " ") ?: "AI empty response."
                }
            } catch (e: Exception) {
                Log.e("SmartShop", "AI Error", e)
                aiResponse = "AI Error: ${e.localizedMessage}"
            } finally {
                isAiLoading = false
            }
        }
    }
}

