@Composable
fun CompareScreen(navController: NavHostController, vm: PriceViewModel, scannedA: String?, scannedB: String?, onClearA: () -> Unit, onClearB: () -> Unit, onScan: (String) -> Unit) {
    val units = listOf("oz", "lb", "g", "kg", "ml", "l", "count", "pack", "gal")
    var nameA by remember { mutableStateOf("") }; var priceA by remember { mutableStateOf("") }; var qtyA by remember { mutableStateOf("") }; var unitA by remember { mutableStateOf("oz") }
    var nameB by remember { mutableStateOf("") }; var priceB by remember { mutableStateOf("") }; var qtyB by remember { mutableStateOf("") }; var unitB by remember { mutableStateOf("oz") }

    LaunchedEffect(scannedA) {
        if (scannedA != null) {
            val (n, q) = vm.fetchProduct(scannedA)
            if (n != null) nameA = n
            parseQuantityAndUnit(q ?: "", units)?.let { qtyA = it.first; unitA = it.second }
            onClearA()
        }
    }
    LaunchedEffect(scannedB) {
        if (scannedB != null) {
            val (n, q) = vm.fetchProduct(scannedB)
            if (n != null) nameB = n
            parseQuantityAndUnit(q ?: "", units)?.let { qtyB = it.first; unitB = it.second }
            onClearB()
        }
    }

    val upA = getPricePerOz(priceA.toDoubleOrNull() ?: 0.0, qtyA.toDoubleOrNull() ?: 0.0, unitA)
    val upB = getPricePerOz(priceB.toDoubleOrNull() ?: 0.0, qtyB.toDoubleOrNull() ?: 0.0, unitB)

    Scaffold(topBar = { TopAppBar(title = { Text("Compare") }, navigationIcon = { IconButton(onClick = { navController.popBackStack() }) { Icon(imageVector = Icons.Default.ArrowBack, contentDescription = "Back") } }) }) { p ->
        LazyColumn(modifier = Modifier.fillMaxSize().padding(p).padding(16.dp), verticalArrangement = Arrangement.spacedBy(16.dp)) {
            item {
                Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surfaceVariant)) {
                    Column(modifier = Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(8.dp)) {
                        Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) { Text("Item A", fontWeight = FontWeight.Bold); IconButton(onClick = { onScan("compareA") }) { Icon(imageVector = Icons.Default.Search, contentDescription = "Scan A") } }
                        OutlinedTextField(nameA, { nameA = it }, label = { Text("Name") }, modifier = Modifier.fillMaxWidth())
                        Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                            OutlinedTextField(priceA, { priceA = it }, label = { Text("$") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                            OutlinedTextField(qtyA, { qtyA = it }, label = { Text("Size") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                        }
                    }
                }
            }
            item {
                Card(colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surfaceVariant)) {
                    Column(modifier = Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(8.dp)) {
                        Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) { Text("Item B", fontWeight = FontWeight.Bold); IconButton(onClick = { onScan("compareB") }) { Icon(imageVector = Icons.Default.Search, contentDescription = "Scan B") } }
                        OutlinedTextField(nameB, { nameB = it }, label = { Text("Name") }, modifier = Modifier.fillMaxWidth())
                        Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                            OutlinedTextField(priceB, { priceB = it }, label = { Text("$") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                            OutlinedTextField(qtyB, { qtyB = it }, label = { Text("Size") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                        }
                    }
                }
            }
            if (upA > 0 && upB > 0) {
                item {
                    val isATie = Math.abs(upA - upB) < 0.0001
                    val winnerIsA = upA < upB
                    val winVal = if (winnerIsA) upA else upB
                    val loseVal = if (winnerIsA) upB else upA
                    val winName = if (winnerIsA) (nameA.ifBlank { "Item A" }) else (nameB.ifBlank { "Item B" })
                    val loseName = if (winnerIsA) (nameB.ifBlank { "Item B" }) else (nameA.ifBlank { "Item A" })
                    
                    val diffPercent = ((loseVal - winVal) / loseVal) * 100

                    Card(modifier = Modifier.fillMaxWidth(), colors = CardDefaults.cardColors(containerColor = if (isATie) Color.LightGray else Color(0xFFE8F5E9))) {
                        Column(modifier = Modifier.padding(16.dp), horizontalAlignment = Alignment.CenterHorizontally) {
                            if (isATie) {
                                Text("It's a Tie!", fontWeight = FontWeight.Bold, color = Color.DarkGray)
                                Text("$${String.format("%.2f", upA)}/oz", style = MaterialTheme.typography.bodyLarge)
                            } else {
                                Text("🏆 $winName is cheaper!", fontWeight = FontWeight.Bold, color = Color(0xFF2E7D32), fontSize = 18.sp)
                                Spacer(Modifier.height(4.dp))
                                Text(
                                    "$winName is less expensive by ${String.format("%.1f", diffPercent)}%, at $${String.format("%.2f", winVal)}/oz compared to $${String.format("%.2f", loseVal)}/oz for $loseName.",
                                    textAlign = TextAlign.Center,
                                    style = MaterialTheme.typography.bodyMedium
                                )
                            }
                        }
                    }
                }
            }
        }
    }
}

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun EntryScreen(navController: NavHostController, vm: PriceViewModel, scannedCode: String?, entryId: Int, onClear: () -> Unit, onLaunchScanner: () -> Unit) {
    var name by remember { mutableStateOf("") }; var priceInput by remember { mutableStateOf("") }; var qtyInput by remember { mutableStateOf("") }
    var unit by remember { mutableStateOf("oz") }; var store by remember { mutableStateOf(vm.lastUsedStore) }; var barcode by remember { mutableStateOf<String?>(null) }
    var unitMenuExpanded by remember { mutableStateOf(false) }; var showSuggestions by remember { mutableStateOf(false) }
    
    val history by vm.getHistoryForProduct(name).collectAsState(initial = emptyList())
    val suggestions by vm.getSuggestedNames(name).collectAsState(initial = emptyList())
    val dateState = rememberDatePickerState(initialSelectedDateMillis = System.currentTimeMillis())
    val units = listOf("oz", "lb", "g", "kg", "ml", "l", "count", "pack", "gal")
    val scope = rememberCoroutineScope()

    LaunchedEffect(entryId) { if (entryId != 0) vm.getEntryById(entryId)?.let { name = it.name; priceInput = it.totalPrice.toString(); qtyInput = it.quantity.toString(); unit = it.unit; barcode = it.barcode; store = it.store } }
    
    LaunchedEffect(scannedCode) {
        if (scannedCode != null) {
            barcode = scannedCode
            scope.launch {
                val localMatch = vm.getLastEntryForName(scannedCode)
                if (localMatch != null) {
                    name = localMatch.name
                    unit = localMatch.unit
                    qtyInput = localMatch.quantity.toString()
                } else {
                    val (n, q) = vm.fetchProduct(scannedCode)
                    if (n != null) name = n
                    parseQuantityAndUnit(q ?: "", units)?.let { qtyInput = it.first; unit = it.second }
                }
            }
            onClear()
        }
    }

    Scaffold(topBar = { TopAppBar(title = { Text("Log Price") }, navigationIcon = { IconButton(onClick = { navController.popBackStack() }) { Icon(imageVector = Icons.Default.ArrowBack, contentDescription = "Back") } }) }) { p ->
        LazyColumn(modifier = Modifier.fillMaxSize().padding(p).padding(16.dp), verticalArrangement = Arrangement.spacedBy(16.dp)) {
            item { Button(onClick = onLaunchScanner, modifier = Modifier.fillMaxWidth()) { Icon(imageVector = Icons.Default.Search, contentDescription = "Scan"); Text("Scan Barcode") } }
            
            // --- LIVE PRICE CONTEXT CARD ---
            if (name.length > 1 && history.isNotEmpty()) {
                item {
                    val historicalUnitPrices = history.map { getPricePerOz(it.totalPrice, it.quantity, it.unit) }
                    val lowPrice = historicalUnitPrices.minOrNull() ?: 0.0
                    val highPrice = historicalUnitPrices.maxOrNull() ?: 0.0
                    val medPrice = calculateMedian(historicalUnitPrices)
                    val currentPriceOz = getPricePerOz(priceInput.toDoubleOrNull() ?: 0.0, qtyInput.toDoubleOrNull() ?: 0.0, unit)

                    Card(
                        modifier = Modifier.fillMaxWidth(),
                        colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.secondaryContainer)
                    ) {
                        Column(Modifier.padding(12.dp)) {
                            Text("Real-Time Price Context", style = MaterialTheme.typography.labelMedium, color = MaterialTheme.colorScheme.primary)
                            Spacer(Modifier.height(4.dp))
                            Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
                                Text("Records: ${history.size}", style = MaterialTheme.typography.bodySmall)
                                Text("Median: $${String.format("%.2f", medPrice)}/oz", style = MaterialTheme.typography.bodySmall)
                            }
                            Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
                                Text("Low: $${String.format("%.2f", lowPrice)}/oz", style = MaterialTheme.typography.bodySmall, fontWeight = FontWeight.Bold, color = Color(0xFF2E7D32))
                                Text("High: $${String.format("%.2f", highPrice)}/oz", style = MaterialTheme.typography.bodySmall)
                            }
                            
                            if (currentPriceOz > 0) {
                                Divider(Modifier.padding(vertical = 8.dp))
                                val isBest = currentPriceOz < (lowPrice + 0.001)
                                val diffPercent = if (medPrice > 0) ((currentPriceOz - medPrice) / medPrice) * 100 else 0.0
                                
                                Row(verticalAlignment = Alignment.CenterVertically) {
                                    Text(
                                        if (isBest) "🌟 NEW BEST PRICE!" 
                                        else if (currentPriceOz <= medPrice) "👍 Better than Median"
                                        else "⚠️ Higher than Median",
                                        fontWeight = FontWeight.Bold,
                                        style = MaterialTheme.typography.bodyMedium,
                                        color = if (isBest || currentPriceOz <= medPrice) Color(0xFF2E7D32) else Color.Red
                                    )
                                }
                                if (!isBest) {
                                    Text(
                                        "${String.format("%.1f", Math.abs(diffPercent))}% ${if (diffPercent > 0) "higher" else "lower"} than median.",
                                        style = MaterialTheme.typography.bodySmall
                                    )
                                }
                            }
                        }
                    }
                }
            }

            item { OutlinedTextField(store, { store = it }, label = { Text("Store") }, modifier = Modifier.fillMaxWidth()) }
            item {
                Box {
                    OutlinedTextField(name, { name = it; showSuggestions = it.isNotEmpty() }, label = { Text("Product Name") }, modifier = Modifier.fillMaxWidth())
                    if (showSuggestions && suggestions.isNotEmpty()) {
                        DropdownMenu(expanded = showSuggestions, onDismissRequest = { showSuggestions = false }, properties = PopupProperties(focusable = false)) {
                            suggestions.forEach { s -> 
                                DropdownMenuItem(
                                    text = { Text(s) }, 
                                    onClick = { 
                                        name = s
                                        showSuggestions = false
                                        scope.launch { 
                                            vm.getLastEntryForName(s)?.let { lastEntry ->
                                                unit = lastEntry.unit
                                                qtyInput = lastEntry.quantity.toString()
                                                barcode = lastEntry.barcode
                                            } 
                                        } 
                                    }
                                ) 
                            }
                        }
                    }
                }
            }
            item {
                Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                    OutlinedTextField(priceInput, { priceInput = it }, label = { Text("Price $") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                    OutlinedTextField(qtyInput, { qtyInput = it }, label = { Text("Size") }, modifier = Modifier.weight(1f), keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal))
                }
            }
            item {
                Box(modifier = Modifier.fillMaxWidth()) {
                    OutlinedTextField(unit, {}, readOnly = true, label = { Text("Unit") }, modifier = Modifier.fillMaxWidth(), trailingIcon = { Icon(imageVector = Icons.Default.ArrowDropDown, contentDescription = "Units", modifier = Modifier.clickable { unitMenuExpanded = true }) })
                    Box(modifier = Modifier.matchParentSize().clickable { unitMenuExpanded = true })
                    DropdownMenu(expanded = unitMenuExpanded, onDismissRequest = { unitMenuExpanded = false }) { units.forEach { u -> DropdownMenuItem(text = { Text(u) }, onClick = { unit = u; unitMenuExpanded = false }) } }
                }
            }
            item { Button(onClick = { if (name.isNotBlank() && priceInput.isNotBlank()) { vm.saveOrUpdatePrice(entryId, name, priceInput, qtyInput, unit, dateState.selectedDateMillis ?: 0, barcode, store); navController.popBackStack() } }, modifier = Modifier.fillMaxWidth().height(60.dp)) { Text("Save") } }
        }
    }
}

@Composable
fun ScannerScreen(onScanned: (String) -> Unit) {
    val context = LocalContext.current; val lifecycleOwner = LocalLifecycleOwner.current
    var hasPermission by remember { mutableStateOf(ContextCompat.checkSelfPermission(context, Manifest.permission.CAMERA) == PackageManager.PERMISSION_GRANTED) }
    val launcher = rememberLauncherForActivityResult(ActivityResultContracts.RequestPermission()) { hasPermission = it }
    var detected by remember { mutableStateOf(false) }
    LaunchedEffect(Unit) { if (!hasPermission) launcher.launch(Manifest.permission.CAMERA) }
    if (hasPermission) {
        AndroidView(factory = { ctx ->
            val previewView = PreviewView(ctx)
            ProcessCameraProvider.getInstance(ctx).addListener({
                val provider = ProcessCameraProvider.getInstance(ctx).get()
                val preview = Preview.Builder().build().apply { setSurfaceProvider(previewView.surfaceProvider) }
                val analysis = ImageAnalysis.Builder().setBackpressureStrategy(ImageAnalysis.STRATEGY_KEEP_ONLY_LATEST).build()
                analysis.setAnalyzer(Executors.newSingleThreadExecutor()) { proxy ->
                    proxy.image?.let { mediaImage ->
                        BarcodeScanning.getClient().process(InputImage.fromMediaImage(mediaImage, proxy.imageInfo.rotationDegrees))
                            .addOnSuccessListener { barcodes -> if (barcodes.isNotEmpty() && !detected) { detected = true; barcodes[0].rawValue?.let { onScanned(it) } } }
                            .addOnCompleteListener { proxy.close() }
                    } ?: proxy.close()
                }
                provider.unbindAll(); provider.bindToLifecycle(lifecycleOwner, CameraSelector.DEFAULT_BACK_CAMERA, preview, analysis)
            }, ContextCompat.getMainExecutor(ctx))
            previewView
        }, modifier = Modifier.fillMaxSize())
    }
}

