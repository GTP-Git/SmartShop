@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun PriceChartScreen(navController: NavHostController, vm: PriceViewModel, productName: String) {
    val history by vm.getHistoryForProduct(productName).collectAsState(initial = emptyList())
    Scaffold(topBar = { 
        TopAppBar(
            title = { Text("Trend: $productName") }, 
            navigationIcon = { IconButton(onClick = { navController.popBackStack() }) { Icon(imageVector = Icons.Default.ArrowBack, contentDescription = "Back") } }
        ) 
    }) { p ->
        Column(modifier = Modifier.padding(p).fillMaxSize().padding(16.dp)) {
            if (history.size < 2) {
                Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) { Text("Need at least 2 entries for a trend.") }
            } else {
                val unitPrices = history.map { getPricePerOz(it.totalPrice, it.quantity, it.unit) }
                val high = unitPrices.maxOrNull() ?: 0.0
                val low = unitPrices.minOrNull() ?: 0.0
                val median = calculateMedian(unitPrices)
                val count = history.size

                // Summary Stats Card
                Card(modifier = Modifier.fillMaxWidth().padding(bottom = 16.dp), colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.secondaryContainer)) {
                    Row(modifier = Modifier.padding(16.dp).fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
                        Column {
                            Text("Entries: $count", style = MaterialTheme.typography.labelLarge)
                            Text("Median: $${String.format("%.2f", median)}/oz", style = MaterialTheme.typography.labelLarge)
                        }
                        Column(horizontalAlignment = Alignment.End) {
                            Text("High: $${String.format("%.2f", high)}/oz", style = MaterialTheme.typography.labelLarge)
                            Text("Low: $${String.format("%.2f", low)}/oz", style = MaterialTheme.typography.labelLarge, color = Color(0xFF2E7D32), fontWeight = FontWeight.Bold)
                        }
                    }
                }

                Canvas(modifier = Modifier.fillMaxWidth().height(300.dp).background(Color.White)) {
                    val lp = 100f // left padding for labels
                    val bp = 80f  // bottom padding for labels
                    val tp = 40f  // top padding
                    val rp = 40f  // right padding
                    val cw = size.width - lp - rp
                    val ch = size.height - tp - bp

                    val maxP = high.toFloat()
                    val minP = low.toFloat()
                    val range = if (maxP - minP == 0f) 1f else maxP - minP

                    // Draw Axes
                    drawLine(Color.Black, Offset(lp, tp), Offset(lp, size.height - bp), 2f)
                    drawLine(Color.Black, Offset(lp, size.height - bp), Offset(size.width - rp, size.height - bp), 2f)

                    val paint = Paint().apply {
                        color = android.graphics.Color.BLACK
                        textSize = 30f
                        typeface = Typeface.DEFAULT_BOLD
                    }

                    // Price Axis Labels (Y)
                    for (i in 0..4) {
                        val priceLabel = minP + (range / 4 * i)
                        val y = (size.height - bp) - (i.toFloat() / 4 * ch)
                        drawContext.canvas.nativeCanvas.drawText(
                            "$${String.format("%.2f", priceLabel)}", 
                            10f, y + 10f, paint
                        )
                    }

                    // Plot Points and Date Labels (X)
                    val spacing = cw / (history.size - 1)
                    val points = history.mapIndexed { i, entry ->
                        val up = getPricePerOz(entry.totalPrice, entry.quantity, entry.unit).toFloat()
                        val x = lp + (i * spacing)
                        val y = (size.height - bp) - ((up - minP) / range * ch)
                        
                        // Date label
                        val dateStr = SimpleDateFormat("MM/dd", Locale.getDefault()).format(Date(entry.date))
                        drawContext.canvas.nativeCanvas.drawText(dateStr, x - 30f, size.height - 20f, paint)
                        
                        Offset(x, y)
                    }

                    // Draw Line
                    val path = ComposePath().apply {
                        moveTo(points[0].x, points[0].y)
                        points.forEach { lineTo(it.x, it.y) }
                    }
                    drawPath(path, Color(0xFF2196F3), style = Stroke(4.dp.toPx()))
                    
                    // Draw Circles
                    points.forEach { drawCircle(Color(0xFF1976D2), 6.dp.toPx(), it) }
                }
            }
        }
    }
}
