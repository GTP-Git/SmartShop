// --- HELPER FUNCTIONS ---

fun getPricePerOz(totalPrice: Double, qty: Double, unit: String): Double {
    if (qty <= 0) return 0.0
    val factor = when (unit.lowercase()) {
        "oz" -> 1.0
        "lb" -> 16.0
        "g" -> 0.035274
        "kg" -> 35.274
        "ml" -> 0.033814
        "l" -> 33.814
        "gal" -> 128.0
        else -> 1.0
    }
    return totalPrice / (qty * factor)
}

fun calculateMedian(list: List<Double>): Double {
    if (list.isEmpty()) return 0.0
    val sorted = list.sorted()
    return if (sorted.size % 2 == 0) {
        (sorted[sorted.size / 2 - 1] + sorted[sorted.size / 2]) / 2.0
    } else {
        sorted[sorted.size / 2]
    }
}

fun parseQuantityAndUnit(rawString: String, validUnits: List<String>): Pair<String, String>? {
    val regex = Regex("([0-9.]+)\\s*([a-zA-Z]+)")
    val matches = regex.findAll(rawString.lowercase()).toList()
    for (match in matches) {
        val candidateQ = match.groupValues[1]
        val parsedUnit = match.groupValues[2]
        val mappedUnit = when {
            parsedUnit.contains("oz") || parsedUnit.contains("ounce") || parsedUnit == "fl" -> "oz"
            parsedUnit.contains("lb") || parsedUnit.contains("pound") -> "lb"
            parsedUnit == "g" || parsedUnit.contains("gram") -> "g"
            parsedUnit == "kg" || parsedUnit.contains("kilo") -> "kg"
            parsedUnit.contains("ml") || parsedUnit.contains("milli") -> "ml"
            parsedUnit == "l" || parsedUnit == "liter" || parsedUnit == "liters" -> "l"
            parsedUnit.contains("gal") -> "gal"
            else -> parsedUnit
        }
        if (validUnits.contains(mappedUnit)) return Pair(candidateQ, mappedUnit)
    }
    return null
}

