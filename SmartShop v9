@Composable
fun ScannerScreen(onScanned: (String) -> Unit) {
    val ctx = LocalContext.current; val lif = LocalLifecycleOwner.current
    var hasPerm by remember { mutableStateOf(ContextCompat.checkSelfPermission(ctx, Manifest.permission.CAMERA) == PackageManager.PERMISSION_GRANTED) }
    val launcher = rememberLauncherForActivityResult(ActivityResultContracts.RequestPermission()) { hasPerm = it }
    var det by remember { mutableStateOf(false) }
    LaunchedEffect(Unit) { if (!hasPerm) launcher.launch(Manifest.permission.CAMERA) }
    if (hasPerm) {
        AndroidView(factory = { c ->
            val pv = PreviewView(c)
            ProcessCameraProvider.getInstance(c).addListener({
                val pr = ProcessCameraProvider.getInstance(c).get(); val pre = Preview.Builder().build().apply { setSurfaceProvider(pv.surfaceProvider) }
                val ana = ImageAnalysis.Builder().setBackpressureStrategy(ImageAnalysis.STRATEGY_KEEP_ONLY_LATEST).build()
                ana.setAnalyzer(Executors.newSingleThreadExecutor()) { px ->
                    px.image?.let { img -> BarcodeScanning.getClient().process(InputImage.fromMediaImage(img, px.imageInfo.rotationDegrees)).addOnSuccessListener { b -> if (b.isNotEmpty() && !det) { det = true; b[0].rawValue?.let { onScanned(it) } } }.addOnCompleteListener { px.close() } } ?: px.close()
                }
                pr.unbindAll(); pr.bindToLifecycle(lif, CameraSelector.DEFAULT_BACK_CAMERA, pre, ana)
            }, ContextCompat.getMainExecutor(c)); pv
        }, modifier = Modifier.fillMaxSize())
    }
}

