@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun PriceChartScreen(navController: NavHostController, vm: PriceViewModel, pName: String) {
    val history by vm.getHistoryForProduct(pName).collectAsState(initial = emptyList())
    Scaffold(topBar = { TopAppBar(title = { Text("Trend: $pName") }, navigationIcon = { IconButton(onClick = { navController.popBackStack() }) { Icon(Icons.Default.ArrowBack, null) } }) }) { p ->
        Column(modifier = Modifier.padding(p).fillMaxSize().padding(16.dp)) {
            if (history.size < 2) { Box(Modifier.fillMaxSize(), contentAlignment = Alignment.Center) { Text("Need at least 2 entries for a trend.") } } else {
                val ups = history.map { getPricePerOz(it.totalPrice, it.quantity, it.unit) }
                val high = ups.maxOrNull() ?: 0.0; val low = ups.minOrNull() ?: 0.0; val med = calculateMedian(ups)
                Card(modifier = Modifier.fillMaxWidth().padding(bottom = 16.dp), colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.secondaryContainer)) { Row(modifier = Modifier.padding(16.dp).fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) { Column { Text("Entries: ${history.size}", style = MaterialTheme.typography.labelLarge); Text("Median: $${String.format("%.2f", med)}/oz", style = MaterialTheme.typography.labelLarge) }; Column(horizontalAlignment = Alignment.End) { Text("High: $${String.format("%.2f", high)}/oz", style = MaterialTheme.typography.labelLarge); Text("Low: $${String.format("%.2f", low)}/oz", style = MaterialTheme.typography.labelLarge, color = Color(0xFF2E7D32), fontWeight = FontWeight.Bold) } } }
                Canvas(modifier = Modifier.fillMaxWidth().height(300.dp).background(Color.White)) {
                    val lp = 100f; val bp = 80f; val tp = 40f; val rp = 40f; val cw = size.width - lp - rp; val ch = size.height - tp - bp
                    val maxP = high.toFloat(); val minP = low.toFloat(); val range = if (maxP - minP == 0f) 1f else maxP - minP
                    drawLine(Color.Black, Offset(lp, tp), Offset(lp, size.height - bp), 2f); drawLine(Color.Black, Offset(lp, size.height - bp), Offset(size.width - rp, size.height - bp), 2f)
                    val paint = Paint().apply { color = android.graphics.Color.BLACK; textSize = 30f; typeface = Typeface.DEFAULT_BOLD }
                    for (i in 0..4) { val prLabel = minP + (range / 4 * i); val y = (size.height - bp) - (i.toFloat() / 4 * ch); drawContext.canvas.nativeCanvas.drawText("$${String.format("%.2f", prLabel)}", 10f, y + 10f, paint) }
                    val sp = cw / (history.size - 1); val pts = history.mapIndexed { i, ent -> val up = getPricePerOz(ent.totalPrice, ent.quantity, ent.unit).toFloat(); val x = lp + (i * sp); val y = (size.height - bp) - ((up - minP) / range * ch); val dStr = SimpleDateFormat("MM/dd", Locale.getDefault()).format(Date(ent.date)); drawContext.canvas.nativeCanvas.drawText(dStr, x - 30f, size.height - 20f, paint); Offset(x, y) }
                    val path = ComposePath().apply { moveTo(pts[0].x, pts[0].y); pts.forEach { lineTo(it.x, it.y) } }; drawPath(path, Color(0xFF2196F3), style = Stroke(4.dp.toPx())); pts.forEach { drawCircle(Color(0xFF1976D2), 6.dp.toPx(), it) }
                }
            }
        }
    }
}
